# profile-service/.env.example
# Copy to /etc/emart/profile.env

APP_ENV=development
PORT=8086

DB_HOST=localhost
DB_PORT=5432
DB_NAME=profiledb
DB_USER=emart_profile
DB_PASSWORD=CHANGE_ME_profile_db_password

# Must match JWT_SECRET across all services
JWT_SECRET=CHANGE_ME_min_32_char_shared_secret_across_all_services

LOG_LEVEL=debug
