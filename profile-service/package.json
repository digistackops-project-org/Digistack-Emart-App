{
  "name": "emart-profile-service",
  "version": "1.0.0",
  "description": "Emart User Profile Service — Phase 7 — Node.js + Express + PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start":       "node src/server.js",
    "dev":         "nodemon src/server.js",
    "test":        "jest --runInBand --forceExit",
    "test:unit":   "jest tests/unit --runInBand --forceExit",
    "test:int":    "jest tests/integration --runInBand --forceExit",
    "test:api":    "jest tests/api --runInBand --forceExit",
    "migrate":     "node src/db/migrate.js"
  },
  "dependencies": {
    "express":          "^4.19.2",
    "pg":               "^8.12.0",
    "jsonwebtoken":     "^9.0.2",
    "bcryptjs":         "^2.4.3",
    "joi":              "^17.13.1",
    "multer":           "^1.4.5-lts.1",
    "sharp":            "^0.33.4",
    "winston":          "^3.13.0",
    "helmet":           "^7.1.0",
    "cors":             "^2.8.5",
    "express-rate-limit":"^7.3.1",
    "node-postgres-migrate": "^1.3.0"
  },
  "devDependencies": {
    "jest":        "^29.7.0",
    "supertest":   "^7.0.0",
    "nodemon":     "^3.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  }
}
