# notification-service/.env.example
APP_ENV=development
PORT=8088

# JWT — same secret as all other services (for verifying user tokens)
JWT_SECRET=CHANGE_ME_min_32_char_shared_secret_across_all_services

# Optional: shared service secret for service-to-service calls without user JWT
SERVICE_SECRET=CHANGE_ME_internal_service_secret

# SMTP configuration (leave blank to use Ethereal test email in development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@emart.com

# For production use one of:
# Gmail:    SMTP_HOST=smtp.gmail.com SMTP_USER=you@gmail.com SMTP_PASS=app-password
# SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASS=SG.xxx
# Mailgun:  SMTP_HOST=smtp.mailgun.org SMTP_USER=postmaster@mg.yourdomain.com

LOG_LEVEL=debug
