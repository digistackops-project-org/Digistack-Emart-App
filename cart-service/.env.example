# cart-service/.env.example
# Copy to /etc/emart/cart.env and fill in values.
# Loaded by systemd EnvironmentFile= directive.

APP_ENV=production
PORT=8081

# MongoDB — cart persistence
MONGO_URI=mongodb://emart_user:change_me@localhost:27017
MONGO_DB=cartdb

# Redis — session cache
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=change_me

# JWT — MUST be identical across ALL Emart services
JWT_SECRET=change_me_use_long_random_string_min_32_chars

# Logging
LOG_LEVEL=warn
