# config/notification.env.example — Production env for Notification Service
APP_ENV=production
PORT=8088
JWT_SECRET=<generated — SAME across all services>
SERVICE_SECRET=<generated>
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.<your_sendgrid_key>
FROM_EMAIL=noreply@emart.com
LOG_LEVEL=warn
