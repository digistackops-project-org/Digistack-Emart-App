# ============================================================
# Book Service — Environment Variables
# Copy to /etc/emart/book.env in production (chmod 640, root:emart)
# ============================================================

# Application
NODE_ENV=production
APP_NAME=emart-book-service
APP_VERSION=1.0.0
SERVER_PORT=8082
LOG_LEVEL=info

# PostgreSQL (BooksDB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=booksdb
DB_USER=emart_books_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONN_TIMEOUT=5000

# Flyway (same credentials, JDBC format)
# Used in CI and DB pipeline: flyway -url=... -user=... -password=...
FLYWAY_URL=jdbc:postgresql://localhost:5432/booksdb
FLYWAY_USER=emart_books_user
FLYWAY_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT — MUST match the JWT_SECRET in login.env and cart.env exactly
JWT_SECRET=COPY_FROM_LOGIN_ENV_FILE

# CORS origin (set to frontend URL or * for dev)
CORS_ORIGIN=http://your-server-ip
