# config/payment.env.example
# Production environment file — copy to /etc/emart/payment.env
# Generated automatically by: sudo bash scripts/install/configure-env.sh
#
# chmod 640 /etc/emart/payment.env
# chown root:emart /etc/emart/payment.env

APP_ENV=production
APP_NAME=emart-payment-service
APP_VERSION=1.0.0
PORT=8084

DB_HOST=localhost
DB_PORT=5432
DB_NAME=paymentdb
DB_USER=emart_payment
DB_PASSWORD=<generated_by_configure-env.sh>

# CRITICAL: identical in login.env, cart.env, books.env, course.env, payment.env
JWT_SECRET=<generated_by_configure-env.sh>

CART_SERVICE_URL=http://localhost:8081

PAYMENT_SIMULATION=true
PAYMENT_SUCCESS_RATE=0.95

LOG_LEVEL=WARN
JPA_SHOW_SQL=false
