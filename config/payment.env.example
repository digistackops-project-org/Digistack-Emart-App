# payment.env.example — copy to /etc/emart/payment.env and fill in values
APP_ENV=production
APP_NAME=emart-payment-service
APP_VERSION=1.0.0

PORT=8084

# PostgreSQL — paymentdb
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paymentdb
DB_USER=emart_payment
DB_PASSWORD=change_me

# JWT — MUST be identical in ALL service env files
JWT_SECRET=change_me_use_long_random_string

# Cart Service URL — for fetching cart and clearing after payment
CART_SERVICE_URL=http://localhost:8081

# Notification Service — Phase 9 integration
# Set SERVICE_SECRET to the same value as notification.env SERVICE_SECRET
NOTIFICATION_SERVICE_URL=http://localhost:8088
NOTIFICATION_SERVICE_SECRET=change_me_match_notification_env

# Payment simulation
PAYMENT_SIMULATION=true
PAYMENT_SUCCESS_RATE=0.95

# Logging
LOG_LEVEL=WARN
JPA_SHOW_SQL=false
