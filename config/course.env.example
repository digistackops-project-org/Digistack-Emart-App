# ============================================================
# course-service/.env.example
# Copy:  cp .env.example .env   (edit values before running)
# Production values live in /etc/emart/course.env
# ============================================================

APP_ENV=development
APP_NAME=emart-course-service
APP_VERSION=1.0.0
PORT=8083
DEBUG=false

# PostgreSQL — CourseDB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coursedb
DB_USER=emart_course
DB_PASSWORD=CHANGE_ME

# JWT — MUST match Login Service JWT_SECRET exactly
JWT_SECRET=CHANGE_ME_MUST_MATCH_LOGIN_AND_ALL_OTHER_SERVICES

# Logging
LOG_LEVEL=INFO
LOG_JSON=false
