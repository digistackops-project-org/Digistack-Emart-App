# ============================================================
# books-service/.env.example
# Copy to .env for local development:
#   cp .env.example .env
#   # Edit .env with real values
# ============================================================

NODE_ENV=development

# HTTP port — Books Service
PORT=8082

# PostgreSQL — BooksDB
DB_HOST=localhost
DB_PORT=5432
DB_NAME=booksdb
DB_USER=emart_books
DB_PASSWORD=CHANGE_ME_BOOKS_DB_PASSWORD
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# JWT — MUST match Login Service JWT_SECRET exactly
# Generate: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=CHANGE_ME_MUST_MATCH_LOGIN_SERVICE_JWT_SECRET

# Logging
LOG_LEVEL=debug
# LOG_FILE=/var/log/emart/books-service.log  # uncomment in prod
