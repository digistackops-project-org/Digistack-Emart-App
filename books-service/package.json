{
  "name": "emart-books-service",
  "version": "1.0.0",
  "description": "Emart Books Microservice — Node.js + Express + PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start":             "node src/server.js",
    "dev":               "nodemon src/server.js",
    "test":              "jest --runInBand",
    "test:unit":         "jest --testPathPattern='tests/unit' --runInBand --coverage",
    "test:integration":  "jest --testPathPattern='tests/integration' --runInBand --forceExit",
    "test:api":          "jest --testPathPattern='tests/api' --runInBand --forceExit",
    "test:ci":           "jest --runInBand --coverage --forceExit",
    "db:migrate":        "bash db/run-flyway.sh migrate",
    "db:info":           "bash db/run-flyway.sh info",
    "db:repair":         "bash db/run-flyway.sh repair",
    "lint":              "eslint src/ --ext .js"
  },
  "dependencies": {
    "express":           "^4.18.2",
    "pg":                "^8.11.3",
    "jsonwebtoken":      "^9.0.2",
    "dotenv":            "^16.3.1",
    "cors":              "^2.8.5",
    "helmet":            "^7.1.0",
    "express-validator": "^7.0.1",
    "morgan":            "^1.10.0",
    "winston":           "^3.11.0"
  },
  "devDependencies": {
    "jest":              "^29.7.0",
    "supertest":         "^6.3.4",
    "nodemon":           "^3.0.2",
    "eslint":            "^8.56.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout":     30000,
    "coverageThreshold": {
      "global": {
        "lines":     70,
        "functions": 70,
        "branches":  60
      }
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
