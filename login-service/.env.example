# login-service/.env.example
# Copy to /etc/emart/login.env and fill in values.
# Loaded by systemd EnvironmentFile= directive.

APP_ENV=production
SPRING_PROFILE=prod
SERVER_PORT=8080

# MongoDB — userdb
# Format: mongodb://username:password@host:port/database?authSource=database
MONGO_URI=mongodb://emart_user:change_me@localhost:27017/userdb?authSource=userdb

# JWT — MUST be identical across ALL Emart services
JWT_SECRET=change_me_use_long_random_string_min_32_chars
JWT_EXPIRATION_MS=86400000

# Logging
LOG_LEVEL=WARN
