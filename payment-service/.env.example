# payment-service/.env.example
# Copy to /etc/emart/payment.env and fill in real values.
# NEVER commit real passwords or JWT_SECRET to git.
#
# Physical server: sudo bash scripts/install/configure-env.sh
# Kubernetes:      kubectl create secret generic emart-payment-secret ...

# ── Application ───────────────────────────────────────────────
APP_ENV=development
APP_NAME=emart-payment-service
APP_VERSION=1.0.0
PORT=8084

# ── PostgreSQL — paymentdb ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paymentdb
DB_USER=emart_payment
DB_PASSWORD=CHANGE_ME_payment_db_password

# ── JWT — MUST match login.env, cart.env, books.env, course.env exactly ──
# If this doesn't match, ALL checkout/order requests return 401
JWT_SECRET=CHANGE_ME_min_32_char_shared_secret_across_all_services

# ── Cart Service integration ──────────────────────────────────
# Used to fetch cart items at checkout and clear cart after payment
CART_SERVICE_URL=http://localhost:8081

# ── Payment simulation ────────────────────────────────────────
# Set PAYMENT_SIMULATION=false and add gateway SDK config to use real payments
PAYMENT_SIMULATION=true
PAYMENT_SUCCESS_RATE=0.95

# ── Logging (dev=false, prod=true) ────────────────────────────
LOG_LEVEL=DEBUG
JPA_SHOW_SQL=true
